# FacturaAI Environment Configuration

# Application
APP_NAME=FacturaAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/v1
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/facturaai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
FREE_TIER_MONTHLY_LIMIT=100
PRO_TIER_MONTHLY_LIMIT=1000
ENTERPRISE_TIER_MONTHLY_LIMIT=10000

# OCR & LLM
GROQ_API_KEY=your_groq_api_key_here
PADDLE_VL_API_URL=https://c6vceb62c4n8zfaf.aistudio-app.com/layout-parsing
PADDLE_VL_TOKEN=your_paddle_vl_token_here

# Mercado Pago (OpenCode MCP: autenticación OAuth con `opencode mcp auth mercadopago-mcp-server`; Access Token solo para la API)
MERCADO_PAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret
MERCADO_PAGO_ENABLED=false

# Storage
STORAGE_PATH=./storage
TEMP_PATH=./temp
MAX_FILE_SIZE_MB=10

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,https://facturaai.com

# Logging
LOG_LEVEL=INFO
